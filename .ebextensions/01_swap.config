commands:
  01_create_swapfile:
    # Add a 1 GB swap file so the t3.micro (1 GB RAM) has headroom and does not
    # OOM-kill Gunicorn under memory pressure. Idempotent: only runs if absent.
    test: test ! -f /var/swapfile
    command: |
      /usr/bin/fallocate -l 1G /var/swapfile || /bin/dd if=/dev/zero of=/var/swapfile bs=1M count=1024
      /bin/chmod 600 /var/swapfile
      /sbin/mkswap /var/swapfile
      /sbin/swapon /var/swapfile
      /bin/grep -q '/var/swapfile' /etc/fstab || echo '/var/swapfile swap swap defaults 0 0' >> /etc/fstab
